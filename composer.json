{
    "name": "rastographer/igdownloader",
    "description": "Instagram media extraction and signed proxy delivery for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Rastographer\\IgDownloader\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rastographer\\IgDownloader\\IgDownloaderServiceProvider"
            ]
        }
    }
}

